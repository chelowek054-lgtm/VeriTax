APP_ENV=development

# Порт в браузере (хост). Внутри контейнера приложение всегда на 8000 (см. docker-compose).
FASTAPI_PORT=80
SESSION_SECRET=change-me-to-random-string

DATA_DIR=.data

QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=veritax_threads

EMBEDDING_DIMENSION=1024
EMBED_BATCH_SIZE=16
EMBED_MAX_CONCURRENT=4
THREAD_TEXT_MAX_CHARS=12000

# Ollama ставится и запускается на вашем ПК (не в Docker). Контейнер приложения ходит на хост так:
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Если приложение и Ollama на одной машине без Docker — http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=bge-m3
OLLAMA_CHAT_MODEL=qwen2.5:3b

RAG_TOP_K=5
ASK_CONTEXT_MAX_CHARS=24000
